<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{{ title or "SpelkBlog" }}</title>
    
    <!-- Prevent flash of white content in dark mode -->
    <script>
      (function() {
        // Check if dark mode is preferred before any rendering
        if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
          document.documentElement.classList.add('dark');
          document.documentElement.style.colorScheme = 'dark';
        } else {
          document.documentElement.style.colorScheme = 'light';
        }
      })();
    </script>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        darkMode: 'media', // Verwendet Systemeinstellungen
        theme: {
          extend: {
            fontFamily: {
              'sans': ['Inter', 'system-ui', 'sans-serif'],
            }
          }
        }
      }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Prism.js for Syntax Highlighting -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-core.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/plugins/autoloader/prism-autoloader.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/plugins/line-numbers/prism-line-numbers.min.js"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/plugins/line-numbers/prism-line-numbers.min.css" rel="stylesheet" />
    
    <style>
      /* Prevent flash of white content - immediate dark mode styles */
      :root {
        color-scheme: light dark;
      }
      
      @media (prefers-color-scheme: dark) {
        html {
          background-color: #111827 !important;
          color: #f9fafb !important;
        }
        body {
          background-color: #111827 !important;
          color: #f9fafb !important;
        }
      }
      
      /* Custom styles für Bilder */
      .prose img {
        border-radius: 0.75rem !important;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05) !important;
        transition: none !important;
      }
      
      /* Dark Mode Schatten für Bilder */
      @media (prefers-color-scheme: dark) {
        .prose img {
          box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.3), 0 4px 6px -2px rgba(0, 0, 0, 0.2) !important;
        }
      }
      
      /* Custom styles für Codeblöcke mit Prism.js Integration */
      .prose pre[class*="language-"] {
        background: linear-gradient(135deg, #1e293b 0%, #334155 100%) !important;
        border: 1px solid #475569 !important;
        border-radius: 0.75rem !important;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06) !important;
        padding: 1.5rem !important;
        margin: 1.5rem 0 !important;
        overflow-x: auto !important;
        position: relative !important;
        font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', 'Fira Code', monospace !important;
        font-size: 0.875rem !important;
        line-height: 1.5 !important;
      }
      
      /* Dark Mode Codeblöcke */
      @media (prefers-color-scheme: dark) {
        .prose pre[class*="language-"] {
          background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%) !important;
          border: 1px solid #334155 !important;
          box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3), 0 2px 4px -1px rgba(0, 0, 0, 0.2) !important;
        }
      }
      
      .prose code[class*="language-"] {
        color: #e2e8f0 !important;
        background: transparent !important;
        font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', 'Fira Code', monospace !important;
        font-size: 0.875rem !important;
        line-height: 1.5 !important;
      }
      
      /* Fallback für Codeblöcke ohne Sprach-Klasse */
      .prose pre:not([class*="language-"]) {
        background: linear-gradient(135deg, #1e293b 0%, #334155 100%) !important;
        border: 1px solid #475569 !important;
        border-radius: 0.75rem !important;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06) !important;
        padding: 1.5rem !important;
        margin: 1.5rem 0 !important;
        overflow-x: auto !important;
        position: relative !important;
      }
      
      @media (prefers-color-scheme: dark) {
        .prose pre:not([class*="language-"]) {
          background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%) !important;
          border: 1px solid #334155 !important;
          box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3), 0 2px 4px -1px rgba(0, 0, 0, 0.2) !important;
        }
      }
      
      .prose pre:not([class*="language-"]) code {
        background: transparent !important;
        color: #e2e8f0 !important;
        font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', 'Fira Code', monospace !important;
        font-size: 0.875rem !important;
        line-height: 1.5 !important;
        padding: 0 !important;
        border-radius: 0 !important;
      }
      
      /* Inline Code - Light Mode */
      .prose code:not(pre code):not([class*="language-"]) {
        background: #f1f5f9 !important;
        color: #1e293b !important;
        border: 1px solid #e2e8f0 !important;
        border-radius: 0.375rem !important;
        padding: 0.25rem 0.375rem !important;
        font-size: 0.875rem !important;
        font-weight: 500 !important;
        font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', 'Fira Code', monospace !important;
      }
      
      /* Inline Code - Dark Mode */
      @media (prefers-color-scheme: dark) {
        .prose code:not(pre code):not([class*="language-"]) {
          background: #374151 !important;
          color: #e5e7eb !important;
          border: 1px solid #4b5563 !important;
        }
      }
      
      /* Code Block Header Effect */
      .prose pre[class*="language-"]::before,
      .prose pre:not([class*="language-"])::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, #3b82f6, #8b5cf6, #ec4899);
        border-radius: 0.75rem 0.75rem 0 0;
      }
      
      /* Prose Text Farben für Dark Mode */
      @media (prefers-color-scheme: dark) {
        .prose {
          color: #e5e7eb !important;
        }
        .prose h1, .prose h2, .prose h3, .prose h4, .prose h5, .prose h6 {
          color: #f9fafb !important;
        }
        .prose p {
          color: #d1d5db !important;
        }
        .prose blockquote {
          background: rgba(59, 130, 246, 0.1) !important;
          border-left-color: #3b82f6 !important;
          color: #d1d5db !important;
        }
        .prose a {
          color: #60a5fa !important;
        }
        .prose a:hover {
          color: #93c5fd !important;
        }
        .prose strong {
          color: #f3f4f6 !important;
        }
        .prose ul > li::marker,
        .prose ol > li::marker {
          color: #9ca3af !important;
        }
      }
      
      /* Enhanced Markdown Styling */
      
      /* Headings */
      .prose h1 {
        font-size: 2.25rem !important;
        font-weight: 800 !important;
        margin: 0 0 1.5rem 0 !important;
        line-height: 1.2 !important;
        border-bottom: 3px solid #3b82f6 !important;
        padding-bottom: 0.75rem !important;
      }
      
      .prose h2 {
        font-size: 1.875rem !important;
        font-weight: 700 !important;
        margin: 2.5rem 0 1rem 0 !important;
        line-height: 1.3 !important;
        position: relative !important;
      }
      
      .prose h2::before {
        content: '' !important;
        position: absolute !important;
        left: -1rem !important;
        top: 50% !important;
        transform: translateY(-50%) !important;
        width: 4px !important;
        height: 1.5rem !important;
        background: linear-gradient(135deg, #3b82f6, #8b5cf6) !important;
        border-radius: 2px !important;
      }
      
      .prose h3 {
        font-size: 1.5rem !important;
        font-weight: 600 !important;
        margin: 2rem 0 0.75rem 0 !important;
        color: #1f2937 !important;
      }
      
      @media (prefers-color-scheme: dark) {
        .prose h1 {
          border-bottom-color: #60a5fa !important;
        }
        .prose h3 {
          color: #e5e7eb !important;
        }
      }
      
      /* Tables */
      .prose table {
        width: 100% !important;
        border-collapse: separate !important;
        border-spacing: 0 !important;
        margin: 2rem 0 !important;
        border-radius: 0.75rem !important;
        overflow: hidden !important;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06) !important;
        border: 1px solid #e5e7eb !important;
      }
      
      .prose table thead {
        background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%) !important;
      }
      
      .prose table th {
        padding: 1rem !important;
        text-align: left !important;
        font-weight: 600 !important;
        font-size: 0.875rem !important;
        text-transform: uppercase !important;
        letter-spacing: 0.05em !important;
        color: #374151 !important;
        border-bottom: 2px solid #e5e7eb !important;
      }
      
      .prose table td {
        padding: 1rem !important;
        border-bottom: 1px solid #f3f4f6 !important;
        font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace !important;
        font-size: 0.875rem !important;
      }
      
      .prose table tr:hover {
        background-color: #f9fafb !important;
      }
      
      .prose table tr:last-child td {
        border-bottom: none !important;
      }
      
      /* Dark Mode Tables */
      @media (prefers-color-scheme: dark) {
        .prose table {
          border-color: #374151 !important;
          background: #1f2937 !important;
        }
        .prose table thead {
          background: linear-gradient(135deg, #374151 0%, #4b5563 100%) !important;
        }
        .prose table th {
          color: #e5e7eb !important;
          border-bottom-color: #4b5563 !important;
        }
        .prose table td {
          border-bottom-color: #374151 !important;
          color: #d1d5db !important;
        }
        .prose table tr:hover {
          background-color: #374151 !important;
        }
      }
      
      /* Lists */
      .prose ul, .prose ol {
        margin: 1.5rem 0 !important;
        padding-left: 2rem !important;
      }
      
      .prose ul li {
        margin: 0.5rem 0 !important;
        position: relative !important;
      }
      
      .prose ul li::marker {
        color: #3b82f6 !important;
        font-size: 1.2em !important;
      }
      
      .prose ol li {
        margin: 0.5rem 0 !important;
      }
      
      .prose ol li::marker {
        color: #3b82f6 !important;
        font-weight: 600 !important;
      }
      
      /* Blockquotes Enhanced */
      .prose blockquote {
        margin: 2rem 0 !important;
        padding: 1.5rem !important;
        border-left: 4px solid #3b82f6 !important;
        background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%) !important;
        border-radius: 0 0.75rem 0.75rem 0 !important;
        font-style: italic !important;
        position: relative !important;
        color: #374151 !important;
      }
      
      .prose blockquote::before {
        content: '"' !important;
        font-size: 4rem !important;
        color: #3b82f6 !important;
        position: absolute !important;
        top: -0.5rem !important;
        left: 1rem !important;
        line-height: 1 !important;
        opacity: 0.3 !important;
      }
      
      .prose blockquote p {
        margin: 0 !important;
        position: relative !important;
        z-index: 1 !important;
        color: inherit !important;
      }
      
      /* Dark Mode Blockquotes */
      @media (prefers-color-scheme: dark) {
        .prose blockquote {
          background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 100%) !important;
          border-left-color: #60a5fa !important;
          color: #e5e7eb !important;
        }
        .prose blockquote::before {
          color: #60a5fa !important;
        }
        .prose blockquote p {
          color: #e5e7eb !important;
        }
      }
      
      /* Horizontal Rules */
      .prose hr {
        margin: 3rem 0 !important;
        border: none !important;
        height: 3px !important;
        background: linear-gradient(90deg, transparent, #3b82f6, transparent) !important;
        border-radius: 1.5px !important;
      }
      
      /* Paragraphs */
      .prose p {
        margin: 1.25rem 0 !important;
        line-height: 1.75 !important;
        font-size: 1rem !important;
      }
      
      /* Links Enhanced */
      .prose a {
        text-decoration: none !important;
        background: linear-gradient(135deg, #3b82f6, #8b5cf6) !important;
        background-clip: text !important;
        -webkit-background-clip: text !important;
        -webkit-text-fill-color: transparent !important;
        font-weight: 500 !important;
        position: relative !important;
      }
      
      .prose a::after {
        content: '' !important;
        position: absolute !important;
        bottom: -2px !important;
        left: 0 !important;
        width: 0 !important;
        height: 2px !important;
        background: linear-gradient(90deg, #3b82f6, #8b5cf6) !important;
        transition: width 0.3s ease !important;
      }
      
      .prose a:hover::after {
        width: 100% !important;
      }
      
      @media (prefers-color-scheme: dark) {
        .prose a {
          background: linear-gradient(135deg, #60a5fa, #a78bfa) !important;
          background-clip: text !important;
          -webkit-background-clip: text !important;
        }
        .prose a::after {
          background: linear-gradient(90deg, #60a5fa, #a78bfa) !important;
        }
      }
      
      /* Prism.js Syntax Highlighting bleibt unverändert */
      .token.comment,
      .token.prolog,
      .token.doctype,
      .token.cdata {
        color: #64748b !important;
      }
      
      .token.punctuation {
        color: #94a3b8 !important;
      }
      
      .token.property,
      .token.tag,
      .token.boolean,
      .token.number,
      .token.constant,
      .token.symbol,
      .token.deleted {
        color: #f87171 !important;
      }
      
      .token.selector,
      .token.attr-name,
      .token.string,
      .token.char,
      .token.builtin,
      .token.inserted {
        color: #34d399 !important;
      }
      
      .token.operator,
      .token.entity,
      .token.url,
      .language-css .token.string,
      .style .token.string {
        color: #60a5fa !important;
      }
      
      .token.atrule,
      .token.attr-value,
      .token.keyword {
        color: #a78bfa !important;
      }
      
      .token.function,
      .token.class-name {
        color: #fbbf24 !important;
      }
      
      .token.regex,
      .token.important,
      .token.variable {
        color: #fb7185 !important;
      }
    </style>
  </head>
  <body class="bg-gray-50 dark:bg-gray-900 font-sans text-gray-900 dark:text-gray-100 leading-relaxed transition-colors duration-300">
    <div class="min-h-screen flex flex-col">
      <!-- Header -->
      <header class="bg-white dark:bg-gray-800 shadow-sm border-b border-gray-200 dark:border-gray-700 relative transition-colors duration-300">
        <!-- Charakteristischer Akzent-Balken -->
        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500"></div>
        
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between items-center py-6">
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white flex items-center">
              <!-- Logo/Icon -->
              <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-purple-600 rounded-lg mr-3 flex items-center justify-center shadow-sm">
                <span class="text-white font-bold text-sm">KF</span>
              </div>
              <a href="/" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors duration-200">
                SpelkBlog
              </a>
            </h1>
            <nav class="hidden sm:block">
              <a href="/" class="text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white px-3 py-2 rounded-md text-sm font-medium transition-colors duration-200">
                Home
              </a>
              <a href="/posts" class="text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white px-3 py-2 rounded-md text-sm font-medium transition-colors duration-200">
                Posts
              </a>
            </nav>
          </div>
        </div>
      </header>

      <!-- Main Content -->
      <main class="flex-1 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-6 sm:p-8 border border-gray-100 dark:border-gray-700 transition-colors duration-300">
          {{ content | safe }}
        </div>
      </main>

      <!-- Footer -->
      <footer class="bg-white dark:bg-gray-800 border-t border-gray-200 dark:border-gray-700 mt-16 transition-colors duration-300">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
          <div class="flex flex-col sm:flex-row justify-between items-center">
            <p class="text-gray-600 dark:text-gray-300 text-sm">
              © 2025 — <span class="font-medium">Keanu Fuchs</span>
            </p>
            <p class="text-gray-500 dark:text-gray-400 text-xs mt-2 sm:mt-0">
              Built with ❤️ and Eleventy
            </p>
          </div>
        </div>
      </footer>
    </div>
  </body>
  
  <script>
    // Listen for changes in color scheme preference
    if (window.matchMedia) {
      const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
      
      function handleColorSchemeChange(e) {
        if (e.matches) {
          document.documentElement.classList.add('dark');
          document.documentElement.style.colorScheme = 'dark';
        } else {
          document.documentElement.classList.remove('dark');
          document.documentElement.style.colorScheme = 'light';
        }
      }
      
      // Listen for changes
      mediaQuery.addListener(handleColorSchemeChange);
      
      // Set initial state (backup in case the inline script didn't work)
      handleColorSchemeChange(mediaQuery);
    }
  </script>
</html>
