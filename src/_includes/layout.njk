    <style>
      /* Prevent flash of white content - immediate dark mode styles */
      :root {
        color-scheme: light dark;
        --header-height: 85px;
      }
      
      @media (prefers-color-scheme: dark) {
        html {
          background-color: #111827 !important;
          color: #f9fafb !important;
        }
        body {
          background-color: #111827 !important;
          color: #f9fafb !important;
        }
      }
      
      /* Custom styles für Bilder */
      .prose img {
        border-radius: 0.75rem !important;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05) !important;
        transition: none !important;
      }
      
      /* Dark Mode Schatten für Bilder */
      @media (prefers-color-scheme: dark) {
        .prose img {
          box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.3), 0 4px 6px -2px rgba(0, 0, 0, 0.2) !important;
        }
      }
      
      /* Custom styles für Codeblöcke mit Prism.js Integration */
      .prose pre[class*="language-"] {
        background: linear-gradient(135deg, #1e293b 0%, #334155 100%) !important;
        border: 1px solid #475569 !important;
        border-radius: 0.75rem !important;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06) !important;
        padding: 1.5rem !important;
        margin: 1.5rem 0 !important;
        overflow-x: auto !important;
        position: relative !important;
        font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', 'Fira Code', monospace !important;
        font-size: 0.875rem !important;
        line-height: 1.5 !important;
      }
      
      /* Dark Mode Codeblöcke */
      @media (prefers-color-scheme: dark) {
        .prose pre[class*="language-"] {
          background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%) !important;
          border: 1px solid #334155 !important;
          box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3), 0 2px 4px -1px rgba(0, 0, 0, 0.2) !important;
        }
      }
      
      .prose code[class*="language-"] {
        color: #e2e8f0 !important;
        background: transparent !important;
        font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', 'Fira Code', monospace !important;
        font-size: 0.875rem !important;
        line-height: 1.5 !important;
      }
      
      /* Fallback für Codeblöcke ohne Sprach-Klasse */
      .prose pre:not([class*="language-"]) {
        background: linear-gradient(135deg, #1e293b 0%, #334155 100%) !important;
        border: 1px solid #475569 !important;
        border-radius: 0.75rem !important;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06) !important;
        padding: 1.5rem !important;
        margin: 1.5rem 0 !important;
        overflow-x: auto !important;
        position: relative !important;
      }
      
      @media (prefers-color-scheme: dark) {
        .prose pre:not([class*="language-"]) {
          background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%) !important;
          border: 1px solid #334155 !important;
          box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3), 0 2px 4px -1px rgba(0, 0, 0, 0.2) !important;
        }
      }
      
      .prose pre:not([class*="language-"]) code {
        background: transparent !important;
        color: #e2e8f0 !important;
        font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', 'Fira Code', monospace !important;
        font-size: 0.875rem !important;
        line-height: 1.5 !important;
        padding: 0 !important;
        border-radius: 0 !important;
      }
      
      /* Inline Code - Light Mode */
      .prose code:not(pre code):not([class*="language-"]) {
        background: #f1f5f9 !important;
        color: #1e293b !important;
        border: 1px solid #e2e8f0 !important;
        border-radius: 0.375rem !important;
        padding: 0.25rem 0.375rem !important;
        font-size: 0.875rem !important;
        font-weight: 500 !important;
        font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', 'Fira Code', monospace !important;
      }
      
      /* Inline Code - Dark Mode */
      @media (prefers-color-scheme: dark) {
        .prose code:not(pre code):not([class*="language-"]) {
          background: #374151 !important;
          color: #e5e7eb !important;
          border: 1px solid #4b5563 !important;
        }
      }
      
      /* Code Block Header Effect */
      .prose pre[class*="language-"]::before,
      .prose pre:not([class*="language-"])::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, #3b82f6, #8b5cf6, #ec4899);
        border-radius: 0.75rem 0.75rem 0 0;
      }
      
    /* Copy button styling */
    .code-block-wrapper {
      position: relative;
    }
    
    .copy-button {
      position: absolute;
      top: 12px;
      right: 12px;
      background: rgba(75, 85, 99, 0.9);
      color: white;
      border: none;
      border-radius: 6px;
      padding: 6px 8px;
      font-size: 12px;
      font-weight: 500;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 4px;
      opacity: 0;
      transition: all 0.2s ease;
      backdrop-filter: blur(4px);
      z-index: 10;
    }
    
    .code-block-wrapper:hover .copy-button {
      opacity: 1;
    }
    
    .copy-button:hover {
      background: rgba(55, 65, 81, 0.95);
      transform: translateY(-1px);
    }
    
    .copy-button.copied {
      background: rgba(16, 185, 129, 0.9);
    }
    
    .copy-button svg {
      flex-shrink: 0;
    }
    
    /* Dark mode copy button adjustments */
    .dark .copy-button {
      background: rgba(31, 41, 55, 0.9);
      color: #e5e7eb;
    }
    
    .dark .copy-button:hover {
      background: rgba(17, 24, 39, 0.95);
    }
    
    .dark .copy-button.copied {
      background: rgba(16, 185, 129, 0.9);
      color: white;
    }

    /* Table of Contents Styles */
    .toc-nav {
      position: fixed;
      top: calc(var(--header-height, 80px) + 20px);
      right: 30px;
      width: 200px;
      max-height: calc(100vh - var(--header-height, 80px) - 60px);
      background: transparent;
      border: none;
      padding: 0;
      z-index: 100;
      font-family: inherit;
    }
    
    .toc-header {
      margin-bottom: 8px;
      padding: 0;
      border: none;
      background: none;
    }
    
    .toc-header h3 {
      font-size: 0.875rem !important;
      font-weight: 600 !important;
      color: #374151 !important;
      margin: 0 !important;
      padding: 0 !important;
      line-height: 1.5 !important;
      letter-spacing: normal !important;
      text-transform: none !important;
    }
    
    @media (prefers-color-scheme: dark) {
      .toc-header h3 {
        color: #d1d5db !important;
      }
    }
    
    .toc-list {
      list-style: none !important;
      margin: 0 !important;
      padding: 0 !important;
      max-height: calc(100vh - var(--header-height, 80px) - 100px);
      overflow-y: auto;
      border-left: 1px solid #e5e7eb;
      padding-left: 0 !important;
    }
    
    @media (prefers-color-scheme: dark) {
      .toc-list {
        border-left-color: #374151;
      }
    }
    
    /* Scrollbar für TOC Liste */
    .toc-list::-webkit-scrollbar {
      width: 4px;
    }
    
    .toc-list::-webkit-scrollbar-track {
      background: transparent;
    }
    
    .toc-list::-webkit-scrollbar-thumb {
      background: rgba(156, 163, 175, 0.5);
      border-radius: 2px;
    }
    
    @media (prefers-color-scheme: dark) {
      .toc-list::-webkit-scrollbar-thumb {
        background: rgba(107, 114, 128, 0.5);
      }
    }
    
    .toc-item {
      margin: 0 !important;
      padding: 0 !important;
      border: none;
      position: relative;
    }
    
    .toc-item.active::before {
      content: '';
      position: absolute;
      left: -1px;
      top: 0;
      bottom: 0;
      width: 2px;
      background: #3b82f6;
    }
    
    @media (prefers-color-scheme: dark) {
      .toc-item.active::before {
        background: #60a5fa;
      }
    }
    
    .toc-link {
      display: block !important;
      padding: 2px 0 2px 16px !important;
      color: #6b7280 !important;
      text-decoration: none !important;
      font-size: 0.8125rem !important;
      line-height: 1.5 !important;
      transition: color 0.15s ease !important;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      background: none !important;
      -webkit-background-clip: unset !important;
      background-clip: unset !important;
      -webkit-text-fill-color: unset !important;
      border-radius: 0;
      font-weight: 400 !important;
    }
    
    .toc-link::after {
      display: none !important;
    }
    
    .toc-link:hover {
      color: #374151 !important;
      background: none !important;
      -webkit-text-fill-color: unset !important;
    }
    
    .toc-item.active .toc-link {
      color: #3b82f6 !important;
      font-weight: 500 !important;
      background: none !important;
      -webkit-text-fill-color: unset !important;
    }
    
    @media (prefers-color-scheme: dark) {
      .toc-link {
        color: #9ca3af !important;
      }
      
      .toc-link:hover {
        color: #d1d5db !important;
      }
      
      .toc-item.active .toc-link {
        color: #60a5fa !important;
      }
    }
    
    /* Einrückung für verschiedene Heading-Level */
    .toc-h1 .toc-link {
      padding-left: 16px !important;
      font-weight: 500 !important;
    }
    
    .toc-h2 .toc-link {
      padding-left: 24px !important;
    }
    
    .toc-h3 .toc-link {
      padding-left: 32px !important;
      font-size: 0.75rem !important;
      opacity: 0.9;
    }
    
    .toc-h4 .toc-link {
      padding-left: 40px !important;
      font-size: 0.75rem !important;
      opacity: 0.8;
    }
    
    /* Responsive Verhalten */
    @media (max-width: 1200px) {
      .toc-nav {
        display: none;
      }
    }
    
    /* Mobile Toggle für kleinere Bildschirme */
    @media (max-width: 768px) {
      .toc-nav {
        position: fixed;
        top: auto;
        bottom: 20px;
        right: 20px;
        left: 20px;
        max-width: none;
        transform: translateY(calc(100% - 60px));
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      }
      
      .toc-nav.expanded {
        transform: translateY(0);
        display: block;
      }
      
      .toc-nav:hover {
        transform: translateY(calc(100% - 60px));
      }
      
      .toc-nav.expanded:hover {
        transform: translateY(0);
      }
    }

    /* Image zoom functionality */
    .zoomable-image {
      cursor: zoom-in;
      border-radius: 8px;
    }
    
    /* Image modal/overlay */
    .image-modal {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      background: rgba(0, 0, 0, 0.9);
      display: flex;
      justify-content: center;
      align-items: center;
      z-index: 9999;
      opacity: 0;
      visibility: hidden;
      transition: all 0.3s ease;
      padding: 20px;
      box-sizing: border-box;
    }
    
    .image-modal.active {
      opacity: 1;
      visibility: visible;
    }
    
    .image-modal-content {
      position: relative;
      max-width: 95vw;
      max-height: 95vh;
      display: flex;
      justify-content: center;
      align-items: center;
    }
    
    .image-modal img {
      max-width: 100%;
      max-height: 100%;
      object-fit: contain;
      border-radius: 8px;
      box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5);
      cursor: zoom-out;
      transition: transform 0.3s ease;
    }
    
    .image-modal-close {
      position: absolute;
      top: -10px;
      right: -10px;
      background: rgba(255, 255, 255, 0.9);
      color: #374151;
      border: none;
      border-radius: 50%;
      width: 36px;
      height: 36px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      font-weight: bold;
      z-index: 10001;
      transition: all 0.2s ease;
      backdrop-filter: blur(4px);
    }
    
    .image-modal-close:hover {
      background: rgba(255, 255, 255, 1);
      transform: scale(1.1);
    }
    
    .dark .image-modal-close {
      background: rgba(31, 41, 55, 0.9);
      color: #e5e7eb;
    }
    
    .dark .image-modal-close:hover {
      background: rgba(31, 41, 55, 1);
    }
    
    /* Loading spinner for images */
    .image-loading {
      display: inline-block;
      width: 40px;
      height: 40px;
      border: 3px solid rgba(255, 255, 255, 0.3);
      border-radius: 50%;
      border-top-color: #ffffff;
      animation: spin 1s ease-in-out infinite;
    }
    
    @keyframes spin {
      to { transform: rotate(360deg); }
    }
    
    /* Prevent body scroll when modal is open */
    body.modal-open {
      overflow: hidden;
    }      /* Prose Text Farben für Dark Mode */
