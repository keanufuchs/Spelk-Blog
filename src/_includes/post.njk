---
layout: layout.njk
---

<div class="relative">
  <nav id="toc" class="toc-nav" aria-label="Table of contents">
    <div class="toc-header">
      <h3>On this page</h3>
    </div>
    <ul id="toc-list" class="toc-list"></ul>
  </nav>

  <div class="article-block">
    <header class="article-masthead">
      <div class="article-masthead-main">
        <p class="label">Article</p>
        <h2>{{ title }}</h2>
      </div>
      <div class="meta">
        <span class="rust">Keanu Fuchs</span><br>
        {{ page.date | date('%B %d, %Y') }}<br>
        Tech Post
      </div>
    </header>
    <div class="article-content prose" id="post-content">
      {{ content | safe }}
    </div>
  </div>

  <nav class="post-nav" aria-label="Post navigation">
    <a href="/" class="back-home">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path>
      </svg>
      Back to Home
    </a>
  </nav>
</div>
