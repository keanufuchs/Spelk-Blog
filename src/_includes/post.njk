<!-- Table of Contents - Fixed Right -->
<nav id="toc" class="toc-nav">
  <div class="toc-header">
    <h3>On this page</h3>
  </div>
  <ul id="toc-list" class="toc-list">
    <!-- TOC wird dynamisch generiert -->
  </ul>
</nav>

<article class="prose prose-lg max-w-none">
  <header class="mb-8 pb-6 border-b border-gray-200 dark:border-gray-800">
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-4 leading-tight !mt-0">{{ title }}</h1>
    <div class="flex items-center text-gray-500 dark:text-gray-400 text-sm">
      <time class="font-medium">
        September 21, 2025
      </time>
      <span class="mx-2">•</span>
      <span>Tech Post</span>
    </div>
  </header>

  <div class="prose prose-lg max-w-none" id="post-content">
    {{ content | safe }}
  </div>
</article>

